# MusicPlayer20 (Expo) environment variables
# Copy this file to .env and fill in your real values.
# Never commit .env — it is gitignored.
#
# These vars are inlined into the client bundle at build time
# (EXPO_PUBLIC_ prefix), so only put values that are safe to ship
# to every device. Server-side secrets (OPENAI_API_KEY, AUDD_API_KEY,
# SPOTIFY_CLIENT_SECRET, SUPABASE service-role key) belong in the
# backend .env at the project root, not here.

# Supabase project URL — Project Settings → API → Project URL
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon (public) key — Project Settings → API → anon public
# Safe to ship ONLY if Row Level Security is enabled on every table.
EXPO_PUBLIC_SUPABASE_KEY=your-anon-key-here
